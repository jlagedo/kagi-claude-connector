{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kagi-claude-connector",
  "main": "src/index.ts",
  "compatibility_date": "2025-06-01",
  "compatibility_flags": ["nodejs_compat"],

  // McpAgent is a Durable Object. The binding name "MCP_OBJECT" is what the
  // `agents` library looks for; the class lives in src/index.ts.
  "durable_objects": {
    "bindings": [{ "name": "MCP_OBJECT", "class_name": "KagiMCP" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["KagiMCP"] }],

  // workers-oauth-provider stores token hashes, encrypted grant props and
  // client registrations here. Create it with:
  //   npx wrangler kv namespace create OAUTH_KV
  // then paste the returned id below.
  "kv_namespaces": [{ "binding": "OAUTH_KV", "id": "REPLACE_WITH_KV_ID" }],

  // Non-secret defaults. Secrets (KAGI_API_KEY, LOGIN_PASSWORD) are set with
  // `wrangler secret put`, never committed.
  "vars": {
    "KAGI_AUTH_SCHEME": "Bot",
    "KAGI_API_BASE": "https://kagi.com/api/v1"
  },

  "observability": { "enabled": true }
}
